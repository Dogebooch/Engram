# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# generated symbol assets (regenerated by `npm run symbols:build`)
/public/symbols/openmoji/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code working memory
CLAUDE.md
CLAUDE-*.md

# Local env
.env*.local

# IDE
.vscode/
.idea/
.DS_Store

# Tauri / Rust build artifacts
/src-tauri/target/
/src-tauri/gen/
/src-tauri/WixTools/
/src-tauri/.cargo/

# Updater signing keys (paranoid — should never be in repo)
*.key
*.key.pub
