{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Engram",
  "version": "0.1.1",
  "identifier": "com.dogebooch.engram",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Engram",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "Dogebooch",
    "category": "Education",
    "shortDescription": "Local mnemonic scene editor",
    "longDescription": "Single-user, local-only desktop app for authoring Picmonic / Sketchy-style mnemonic scenes."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Dogebooch/Engram/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCMTQ1NEYxRDE5NzlFMkEKUldRcW5wZlI4VlFVaXcrWmsyWnQ1eG92ZzBGenB6blFkUlgrbzYxcWJPWFBTb1J6TTFNbm9RaDIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
